# =============================================================================
# Windsurf Cascade MCP Servers — Environment Variable Template
# =============================================================================
#
# Copy this file to .env and fill in the real values:
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
#
# =============================================================================
#
# Sections:
#   1. GitHub MCP Server (Essential)
#   2. Slack MCP Server (Recommended)
#   3. SonarQube MCP Server (Recommended) [Placeholder]
#   4. Codecov MCP Server (Recommended) [Placeholder]
#   5. JIRA MCP Server (Optional)
#   6. ClickUp MCP Server (Optional)
#
# =============================================================================


# -----------------------------------------------------------------------------
# 1. GitHub MCP Server (Essential)
# -----------------------------------------------------------------------------
#
# GitHub Personal Access Token (PAT)
# Required scopes: repo, read:org, workflow
#
# How to obtain:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Name: "Windsurf Cascade MCP"
#   4. Select scopes:
#      - repo (Full control of private repositories)
#      - read:org (Read org and team membership)
#      - workflow (Update GitHub Action workflows)
#   5. Generate token and copy it immediately
#
# Used by: GitHub MCP server to access PR status, CI results, repository data
#
GITHUB_TOKEN=




# -----------------------------------------------------------------------------
# 2. Slack MCP Server (Recommended)
# -----------------------------------------------------------------------------
#
# Slack Bot User OAuth Token and Team ID
# Required scopes: chat:write, channels:read, im:write
#
# How to obtain:
#   1. Go to https://api.slack.com/apps
#   2. Create new app or use existing
#   3. OAuth & Permissions → Add Bot Token Scopes:
#      - chat:write (Send messages)
#      - channels:read (View basic channel info)
#      - im:write (Start direct messages)
#   4. Install app to workspace
#   5. Copy "Bot User OAuth Token" (xoxb-...)
#   6. Get Team ID from Workspace Settings → Workspace ID (T...)
#
# Used by: Slack MCP server to send notifications and messages
#
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=








# -----------------------------------------------------------------------------
# 3. SonarQube MCP Server (Recommended)
# -----------------------------------------------------------------------------
#
# Official SonarSource implementation: https://github.com/SonarSource/sonarqube-mcp-server
# Docker image: mcp/sonarqube
#
# Choose ONE of the following configurations:
#
# Option A: SonarQube Cloud (recommended for most users)
# --------------------------------------------------------
# How to obtain:
#   1. Log in to https://sonarcloud.io
#   2. Go to My Account → Security → Generate Tokens
#   3. Name: "Windsurf Cascade MCP"
#   4. Type: User Token
#   5. Generate and copy token
#   6. Note your organization key (found in Organization settings)
#
# Required for SonarQube Cloud:
SONARQUBE_TOKEN=
SONARQUBE_ORG=

# Option B: SonarQube Server (self-hosted)
# -----------------------------------------
# How to obtain:
#   1. Log in to your SonarQube Server instance
#   2. Go to My Account → Security → Generate Tokens
#   3. Name: "Windsurf Cascade MCP"
#   4. Type: User Token
#   5. Generate and copy token
#   6. Note your server URL
#
# Required for SonarQube Server (leave SONARQUBE_ORG empty):
# SONARQUBE_TOKEN=your_token_here
# SONARQUBE_URL=https://sonarqube.your-company.com

# Optional Configuration
# ----------------------
# Project key to scope analysis to a specific project
# Leave empty to access all projects
SONARQUBE_PROJECT_KEY=

# Enable debug logging (true/false)
# Default: false
SONARQUBE_DEBUG_ENABLED=false

# Used by: SonarQube MCP server to access code quality, security analysis,
#          quality gates, code coverage, and security hotspots


# -----------------------------------------------------------------------------
# 4. Codecov MCP Server (Recommended) [PLACEHOLDER]
# -----------------------------------------------------------------------------
#
# Codecov Token and Repository
# [VERIFY MCP SERVER IMPLEMENTATION EXISTS]
#
# How to obtain:
#   1. Log in to Codecov (https://codecov.io)
#   2. Go to repository settings
#   3. Copy the repository token
#   4. Note repository in owner/repo format
#
# Used by: Codecov MCP server to access test coverage data
#
CODECOV_TOKEN=
CODECOV_REPO=owner/repo


# -----------------------------------------------------------------------------
# 5. JIRA MCP Server (Optional)
# -----------------------------------------------------------------------------
#
# JIRA Cloud URL, Email, and API Token
# Only needed if using JIRA for issue tracking
#
# How to obtain:
#   1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
#   2. Create API token
#   3. Name: "Windsurf Cascade MCP"
#   4. Copy token
#   5. Note your JIRA URL and email
#
# Used by: JIRA MCP server to access issue tracking data
#
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=


# -----------------------------------------------------------------------------
# 6. ClickUp MCP Server (Optional)
# -----------------------------------------------------------------------------
#
# ClickUp API Token and Team ID
# Only needed if using ClickUp for issue tracking
#
# How to obtain:
#   1. Go to https://app.clickup.com/settings/apps
#   2. Generate API token
#   3. Copy token
#   4. Optional: Get Team ID from workspace URL (https://app.clickup.com/<team_id>/home)
#
# Used by: ClickUp MCP server to access issue tracking data
#
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=
