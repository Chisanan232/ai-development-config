# =============================================================================
# Windsurf Cascade MCP Servers — Environment Variable Template
# =============================================================================
#
# Copy this file to .env and fill in the real values:
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
#
# =============================================================================
#
# Sections:
#   1. Codecov MCP Server (Recommended) [HTTP-based]
#   2. JIRA MCP Server (Optional) [HTTP-based]
#   3. ClickUp MCP Server (Optional) [HTTP-based]
#   4. DataDog MCP Server (Optional) [HTTP-based]
#   5. Sentry MCP Server (Optional) [HTTP-based]
#   6. Confluence MCP Server (Optional) [HTTP-based]
#
# Note: GitHub, Slack, and SonarQube now use native Windsurf MCP integration
#       and are configured directly in .windsurf/mcp_config.json
#
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Codecov MCP Server (Recommended) [HTTP-based]
# -----------------------------------------------------------------------------
#
# Codecov Token and Repository
# [VERIFY MCP SERVER IMPLEMENTATION EXISTS]
#
# How to obtain:
#   1. Log in to Codecov (https://codecov.io)
#   2. Go to repository settings
#   3. Copy the repository token
#   4. Note repository in owner/repo format
#
# Used by: Codecov MCP server to access test coverage data
#
CODECOV_TOKEN=
CODECOV_ORG=


# -----------------------------------------------------------------------------
# 2. JIRA MCP Server (Optional) [HTTP-based]
# -----------------------------------------------------------------------------
#
# JIRA Cloud URL, Email, and API Token
# Only needed if using JIRA for issue tracking
#
# How to obtain:
#   1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
#   2. Create API token
#   3. Name: "Windsurf Cascade MCP"
#   4. Copy token
#   5. Note your JIRA URL and email
#
# Used by: JIRA MCP server to access issue tracking data
#
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=


# -----------------------------------------------------------------------------
# 3. ClickUp MCP Server (Optional) [HTTP-based]
# -----------------------------------------------------------------------------
#
# ClickUp API Token and Team ID
# Only needed if using ClickUp for issue tracking
#
# How to obtain:
#   1. Go to https://app.clickup.com/settings/apps
#   2. Generate API token
#   3. Copy token
#   4. Optional: Get Team ID from workspace URL (https://app.clickup.com/<team_id>/home)
#
# Used by: ClickUp MCP server to access issue tracking data
#
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=


# -----------------------------------------------------------------------------
# 4. DataDog MCP Server (Optional) [HTTP-based]
# -----------------------------------------------------------------------------
#
# DataDog API Key and Application Key
# Only needed if using DataDog for observability
#
# How to obtain:
#   1. Log in to DataDog (https://app.datadoghq.com)
#   2. Go to Organization Settings → API Keys
#   3. Create API Key: "Windsurf Cascade MCP"
#   4. Go to Organization Settings → Application Keys
#   5. Create Application Key: "Windsurf Cascade MCP"
#   6. Note your DataDog site (e.g., datadoghq.com, datadoghq.eu)
#
# Used by: DataDog MCP server to access metrics, logs, and monitoring data
#
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com


# -----------------------------------------------------------------------------
# 5. Sentry MCP Server (Optional) [HTTP-based]
# -----------------------------------------------------------------------------
#
# Sentry Auth Token and Organization
# Only needed if using Sentry for error tracking
#
# How to obtain:
#   1. Log in to Sentry (https://sentry.io)
#   2. Go to Settings → Account → API → Auth Tokens
#   3. Create new token: "Windsurf Cascade MCP"
#   4. Scopes: project:read, event:read, org:read
#   5. Copy token
#   6. Note your organization slug
#
# Used by: Sentry MCP server to access error tracking and monitoring data
#
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_URL=https://sentry.io


# -----------------------------------------------------------------------------
# 6. Confluence MCP Server (Optional) [HTTP-based]
# -----------------------------------------------------------------------------
#
# Confluence URL, Email, and API Token
# Only needed if using Confluence for knowledge base search
#
# How to obtain:
#   1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
#   2. Create API token: "Windsurf Cascade MCP"
#   3. Copy token
#   4. Note your Confluence URL and email
#
# Used by: Confluence MCP server to search documentation and knowledge base
#
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=
