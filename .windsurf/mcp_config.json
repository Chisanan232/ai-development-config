{
  "mcpServers": {
    "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    },
    "git": {
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/git"
      ],
      "command": "docker"
    },
    "github-mcp-server": {
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "command": "docker",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_your_github_personal_access_token"
      }
    },
    "memory": {
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/memory"
      ],
      "command": "docker"
    },
    "slack": {
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SLACK_BOT_TOKEN",
        "-e",
        "SLACK_TEAM_ID",
        "mcp/slack"
      ],
      "command": "docker",
      "env": {
        "SLACK_BOT_TOKEN": "xoxb-your-slack-bot-token",
        "SLACK_TEAM_ID": "your_slack_team_id"
      }
    },
    "sonarqube": {
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube",
        "stdio"
      ],
      "command": "docker",
      "env": {
        "SONARQUBE_ORG": "your_sonarqube_org",
        "SONARQUBE_TOKEN": "your_sonarqube_token",
        "SONARQUBE_URL": "https://sonarcloud.io"
      }
    },
    "terraform": {
      "args": [
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ],
      "command": "docker"
    },
    "jira": {
      "serverUrl": "http://localhost:8100/sse",
      "disabled": true,
      "metadata": {
        "capability": "issue_tracking",
        "priority": "optional",
        "description": "Task and issue tracking",
        "docker_service": "mcp-jira",
        "note": "Requires docker compose --profile optional up -d mcp-jira"
      }
    },
    "clickup": {
      "serverUrl": "http://localhost:8101/sse/sse",
      "disabled": true,
      "metadata": {
        "capability": "issue_tracking",
        "priority": "optional",
        "description": "Task and issue tracking (alternative to JIRA)",
        "docker_service": "mcp-clickup",
        "note": "Requires docker compose --profile optional up -d mcp-clickup"
      }
    },
    "codecov": {
      "serverUrl": "http://localhost:8105/mcp",
      "disabled": true,
      "metadata": {
        "capability": "coverage_reporting",
        "priority": "recommended",
        "description": "Test coverage tracking and reporting",
        "docker_service": "mcp-codecov",
        "note": "Requires docker compose up -d mcp-codecov"
      }
    },
    "datadog": {
      "serverUrl": "http://localhost:8106/mcp",
      "disabled": true,
      "metadata": {
        "capability": "observability",
        "priority": "optional",
        "description": "Production monitoring and metrics",
        "docker_service": "mcp-datadog",
        "note": "Requires docker compose --profile optional up -d mcp-datadog"
      }
    },
    "sentry": {
      "serverUrl": "http://localhost:8107/mcp",
      "disabled": true,
      "metadata": {
        "capability": "observability",
        "priority": "optional",
        "description": "Error tracking and monitoring",
        "docker_service": "mcp-sentry",
        "note": "Requires docker compose --profile optional up -d mcp-sentry"
      }
    },
    "confluence": {
      "serverUrl": "http://localhost:8108/mcp",
      "disabled": true,
      "metadata": {
        "capability": "knowledge_search",
        "priority": "optional",
        "description": "Documentation and knowledge base search",
        "docker_service": "mcp-confluence",
        "note": "Requires docker compose --profile optional up -d mcp-confluence"
      }
    }
  }
}
