{
  "mcpServers": {
    "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    },
    "git": {
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/git"
      ],
      "command": "docker"
    },
    "github-mcp-server": {
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "command": "docker",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_your_github_personal_access_token"
      }
    },
    "memory": {
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/memory"
      ],
      "command": "docker"
    },
    "slack": {
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SLACK_BOT_TOKEN",
        "-e",
        "SLACK_TEAM_ID",
        "mcp/slack"
      ],
      "command": "docker",
      "env": {
        "SLACK_BOT_TOKEN": "xoxb-your-slack-bot-token",
        "SLACK_TEAM_ID": "your_slack_team_id"
      }
    },
    "sonarqube": {
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube",
        "stdio"
      ],
      "command": "docker",
      "env": {
        "SONARQUBE_ORG": "your_sonarqube_org",
        "SONARQUBE_TOKEN": "your_sonarqube_token",
        "SONARQUBE_URL": "https://sonarcloud.io"
      }
    },
    "terraform": {
      "args": [
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ],
      "command": "docker"
    }
  }
}
