{
  "mcpServers": {
    "github": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "capabilities": ["code_repository", "issue_tracking"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "capabilities": ["fetch"]
    }
  }
}
