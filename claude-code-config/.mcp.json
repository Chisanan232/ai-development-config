{
  "mcpServers": {
    "github": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "capabilities": ["code_repository", "issue_tracking"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "capabilities": ["fetch"]
    },
    "sonarqube": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "SONAR_TOKEN",
        "-e", "SONAR_HOST_URL",
        "mcp/sonarqube"
      ],
      "env": {
        "SONAR_TOKEN": "${SONAR_TOKEN}",
        "SONAR_HOST_URL": "${SONAR_HOST_URL}"
      },
      "capabilities": ["static_analysis"],
      "_role": "First-class quality gate: run before every PR merge decision via pr-health-check and pr-readiness skills"
    },
    "codecov": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "CODECOV_TOKEN",
        "mcp/codecov"
      ],
      "env": {
        "CODECOV_TOKEN": "${CODECOV_TOKEN}"
      },
      "capabilities": ["coverage_reporting"],
      "disabled": true
    },
    "slack": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "SLACK_BOT_TOKEN",
        "-e", "SLACK_TEAM_ID",
        "ghcr.io/chisanan232/slack-mcp-server:latest"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      },
      "_note": "[VERIFY IMAGE README] Confirm required env vars and runtime args at https://github.com/chisanan232/slack-mcp-server before enabling",
      "capabilities": ["communication"],
      "disabled": true
    },
    "clickup": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "CLICKUP_API_TOKEN",
        "ghcr.io/chisanan232/clickup-mcp-server:latest"
      ],
      "env": {
        "CLICKUP_API_TOKEN": "${CLICKUP_API_TOKEN}"
      },
      "_note": "[VERIFY IMAGE README] Confirm required env vars and runtime args at https://github.com/chisanan232/clickup-mcp-server before enabling",
      "capabilities": ["issue_tracking"],
      "disabled": true
    },
    "datadog": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "DD_API_KEY",
        "-e", "DD_APP_KEY",
        "mcp/datadog"
      ],
      "env": {
        "DD_API_KEY": "${DD_API_KEY}",
        "DD_APP_KEY": "${DD_APP_KEY}"
      },
      "capabilities": ["observability"],
      "disabled": true
    }
  }
}
