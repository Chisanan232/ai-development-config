# ~/.claude/hooks/config.env — Claude Code hook and utility configuration
#
# Copy this file to ~/.claude/config.env and fill in values for your environment.
# All hooks and utility scripts source this file at startup if it exists.
# Environment variables set externally (e.g., in CI) take precedence over values here.
#
# Usage in hooks:
#   [ -f "${HOME}/.claude/config.env" ] && source "${HOME}/.claude/config.env"

# ── Paths ────────────────────────────────────────────────────────────────────

# Base directory for per-ticket workflow state JSON files
# Default: ~/.claude/workflow-state
# CLAUDE_WORKFLOW_STATE_DIR="${HOME}/.claude/workflow-state"

# Base directory for circuit breaker state files
# Default: ~/.claude/circuit-breaker
# CLAUDE_CIRCUIT_BREAKER_DIR="${HOME}/.claude/circuit-breaker"

# Base directory for per-project/branch test pass sentinels
# Default: ~/.claude/sentinels
# CLAUDE_SENTINEL_DIR="${HOME}/.claude/sentinels"

# Directory for the append-only JSONL audit log
# Default: ~/.claude/audit
# CLAUDE_AUDIT_LOG_DIR="${HOME}/.claude/audit"

# Directory for the structured decision log
# Default: ~/.claude/decisions
# CLAUDE_DECISION_LOG_DIR="${HOME}/.claude/decisions"

# ── Issue tracker routing ────────────────────────────────────────────────────

# Which issue tracking MCP server to use for ticket operations.
# Values: "github" | "clickup"
# Default: github
# CLAUDE_ISSUE_TRACKER="github"

# ── Ticket context ───────────────────────────────────────────────────────────

# Active ticket reference for the current session.
# Set by ticket-pickup-check (written to .claude/.current-ticket in the repo).
# Can be overridden here for CI environments where the ticket ref is known.
# CLAUDE_CURRENT_TICKET="PROJ-123"

# ── Browser / E2E testing ────────────────────────────────────────────────────

# Command to run E2E/browser tests. If unset, qa-agent will note the gap.
# Example: "npx playwright test" or "pytest tests/e2e/"
# CLAUDE_E2E_COMMAND="npx playwright test"

# ── Decision log ─────────────────────────────────────────────────────────────

# Set to 0 to disable the structured decision log (lean/CI environments).
# Default: 1 (enabled)
# CLAUDE_DECISION_LOG_ENABLED="1"

# Maximum length of the context snippet captured in each decision log entry.
# Default: 500 characters
# CLAUDE_DECISION_LOG_MAX_CONTEXT="500"

# ── Audit log ────────────────────────────────────────────────────────────────

# Set to 1 to skip audit logging entirely.
# Default: 0 (audit enabled)
# CLAUDE_SKIP_AUDIT="0"

# ── Circuit breaker ───────────────────────────────────────────────────────────

# Default consecutive failure threshold before the circuit opens.
# Individual skills may override this with an explicit threshold argument.
# Default: 5
# CLAUDE_CIRCUIT_BREAKER_THRESHOLD="5"

# ── Stale PR threshold ────────────────────────────────────────────────────────

# Number of days of inactivity before dev-lead-agent considers a PR stale.
# Used by pr-health-check and dev-lead-agent when closing stale PRs.
# Default: 14
# CLAUDE_STALE_PR_DAYS="14"
